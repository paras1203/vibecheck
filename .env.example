# Firebase client (safe to expose in browser; restrict domain in Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=
# Usually <projectId>.firebaseapp.com — optional if omitted (derived from project id).
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server-only; set in Vercel as encrypted env — never NEXT_PUBLIC_)
FIREBASE_CLIENT_EMAIL=
# Paste key with \n for newlines, or single line; code replaces \\n
FIREBASE_PRIVATE_KEY=

# Google AI (required for roasts)
GOOGLE_GENAI_API_KEY=

# PageSpeed Insights API (optional). When set, roasts include lab performance (score, LCP, CLS, TBT) and a short Gemini speed summary when GOOGLE_GENAI_API_KEY is set.
# PAGESPEED_API_KEY=
# Optional: mobile (default) or desktop Lighthouse run.
# PAGESPEED_STRATEGY=mobile

# Monthly session figures in revenue-leak math are illustrative: Gemini estimates from domain context when GOOGLE_GENAI_API_KEY is set, else industry benchmarks—not real analytics.
# If PAGESPEED_API_KEY was ever exposed publicly, rotate it in Google Cloud Console.

# Admin (optional): same email as your Firebase login. Used for full report access, Social Content Pack API, and home-page reset.
# Server verification prefers ADMIN_EMAIL; client UI uses NEXT_PUBLIC_ADMIN_EMAIL (set both to the same value in .env.local).
# ADMIN_EMAIL=
# NEXT_PUBLIC_ADMIN_EMAIL=

# Assembly-line workers (visuals / copy / tech): primary then one fallback on retryable errors
GEMINI_WORKER_MODEL_PRIMARY=gemini-2.0-flash-001
GEMINI_WORKER_MODEL_FALLBACK=gemini-1.5-flash

# Final long-form roast script: primary then one fallback
GEMINI_ROAST_MODEL_PRIMARY=gemini-2.5-pro
GEMINI_ROAST_MODEL_FALLBACK=gemini-1.5-pro-latest

# Optional shorthand if you omit worker/roast-specific vars above:
# GEMINI_MODEL_PRIMARY=
# GEMINI_MODEL_FALLBACK=

# Razorpay (billing): Dashboard → Account & Settings → API Keys.
# Test/sandbox: key id starts with rzp_test_ (no real money). Live: rzp_live_.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# Billing currency for Orders API (default INR for India keys). Use USD only if international payments are enabled.
# RAZORPAY_CURRENCY=INR
# Optional INR amounts in paise (defaults 159900 ≈ Pro, 409900 ≈ Agency pack).
# PLAN_PRO_AMOUNT_PAISE=159900
# PLAN_AGENCY_AMOUNT_PAISE=409900
# When RAZORPAY_CURRENCY=USD, amounts are fixed at 1900 / 5900 cents ($19 / $59).

# Cursor: Razorpay Remote MCP — https://razorpay.com/docs/mcp-server/remote/
# Add to .cursor/mcp.json env AUTH_HEADER as: Basic <base64 of KEY_ID:KEY_SECRET> (see Razorpay docs). Endpoint: https://mcp.razorpay.com/mcp

# When true, roast pages unlock the full report for the browser session on "Unlock Full Report" (no payment). Remove or set false when billing is live.
# NEXT_PUBLIC_SKIP_PAYMENT_UNLOCK=true

# Next.js (optional): Calendly / Cal.com / etc. for landing “Book a demo”; falls back to mailto NEXT_PUBLIC_ADMIN_EMAIL or #pricing
# NEXT_PUBLIC_DEMO_BOOKING_URL=

# Credits & promos (client-readable defaults for new signups; set in .env.local)
# Default 20 signup credits (not tied to per-roast cost).
# NEXT_PUBLIC_DEFAULT_NEW_USER_CREDITS=20
# Logged-in POST /api/roast debits when `idToken` is sent. Default = 1 credit per roast.
# ROAST_CREDITS_PER_GENERATION=1
# NEXT_PUBLIC_PROMO_ACTIVE=true
# NEXT_PUBLIC_PROMO_BONUS_ROAST_CREDITS=2
# Set to "true" only if home-page previews should decrement Firestore credits (default: free preview).
# NEXT_PUBLIC_PREVIEW_ROAST_USES_CREDITS=false

# Revenue model: illustrative order value when quick-scan finds no pricing-intent + currency pair (server-side).
# DEFAULT_REVENUE_MODEL_AOV_USD=29

# Razorpay pack → audit credits (server-side; must match product expectations)
# PLAN_PRO_AUDIT_CREDITS=1
# PLAN_AGENCY_AUDIT_CREDITS=5

# Optional custom line under the URL input on landing (hero + comparison). Leave unset for no subline.
# NEXT_PUBLIC_ROAST_INPUT_MICROCOPY=
