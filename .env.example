# Database: this app uses Cloud Firestore (SDK: firebase/firestore), not the older Realtime Database.
# In Firebase Console go to Build → Firestore Database → Create database (start in test mode, then deploy rules).
# Firestore collections: `users` (profiles + credits), `payments` (Dodo/Razorpay idempotency by payment id).

# Payments: Dodo (https://docs.dodopayments.com/). Create one-time USD products matching app prices:
# — Pro roast credit (~$29), — Agency bundle of 5 credits (~$99), — optional sandbox “free tier test” ($0.10).
# DODO_PAYMENTS_API_KEY=              # Bearer API key from dashboard (server-only; never NEXT_PUBLIC_*)
# DODO_PAYMENTS_ENVIRONMENT=test_mode # or live_mode when going live
# NEXT_PUBLIC_DODO_PAYMENTS_ENVIRONMENT=test_mode  # Inline checkout SDK; mirror DODO_PAYMENTS_ENVIRONMENT (live_mode → live)
# DODO_PRODUCT_PRO_ID=pdt_0NeJhEIYxzn5ycHUSYz3m
# DODO_PRODUCT_AGENCY_PACK_ID=pdt_0NeJhQiq3J3VLhqmImLCi
# DODO_PRODUCT_FREE_TEST_ID=pdt_0NeJhZaPJ78uKirBaGRF6

# Site URL used for checkout return/cancel redirects when building Dodo sessions (set in prod).
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Optional: Razorpay (deprecated in this codebase; omit unless you fork restore)

# Firebase client (safe to expose in browser; restrict domain in Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=
# Usually <projectId>.firebaseapp.com — optional if omitted (derived from project id).
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional; Web app Analytics measurementId from Firebase console (enables measurementId in client config).
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server-only; set in Vercel as encrypted env — never NEXT_PUBLIC_)
FIREBASE_CLIENT_EMAIL=
# Paste key with \n for newlines, or single line; code replaces \\n
FIREBASE_PRIVATE_KEY=

# Google AI (required for roasts)
GOOGLE_GENAI_API_KEY=

# --- Two LLM stacks (each: primary + one fallback = 4 model IDs total) ---
# Preferred names (override GEMINI_* below when set):
# LLM 1 = multimodal + copy + tech workers (analyzeVisuals / analyzeCopy / analyzeTech).
LLM_1_PRIMARY=gemini-2.5-flash-lite
LLM_1_FALLBACK=gemini-2.5-flash
# LLM 2 = narrative roast, executive insight JSON, PageSpeed summary (generateRoastWithFallback).
LLM_2_PRIMARY=gemini-2.5-pro
LLM_2_FALLBACK=gemini-3-flash-preview

# PageSpeed Insights API (optional). When set, roasts include lab performance (score, LCP, CLS, TBT) and a short Gemini speed summary when GOOGLE_GENAI_API_KEY is set.
# PAGESPEED_API_KEY=
# Optional: mobile (default) or desktop Lighthouse run.
# PAGESPEED_STRATEGY=mobile

# Monthly session figures in revenue-leak math are illustrative: Gemini estimates from domain context when GOOGLE_GENAI_API_KEY is set, else industry benchmarks—not real analytics.
# If PAGESPEED_API_KEY was ever exposed publicly, rotate it in Google Cloud Console.

# Admin (optional): same email as your Firebase login. Used for full report access, Social Content Pack API, home-page reset, and /dashboard/admin/analytics.
# Server verification prefers ADMIN_EMAIL; client UI uses NEXT_PUBLIC_ADMIN_EMAIL (set both to the same value in .env.local).
# ADMIN_EMAIL=
# NEXT_PUBLIC_ADMIN_EMAIL=

# Legacy aliases (used if LLM_1_* / LLM_2_* are unset): workers vs narrative models
GEMINI_WORKER_MODEL_PRIMARY=gemini-2.5-flash-lite
GEMINI_WORKER_MODEL_FALLBACK=gemini-2.5-flash
GEMINI_ROAST_MODEL_PRIMARY=gemini-2.5-pro
GEMINI_ROAST_MODEL_FALLBACK=gemini-3-flash-preview

# Optional shorthand if you omit worker/roast-specific vars above:
# GEMINI_MODEL_PRIMARY=
# GEMINI_MODEL_FALLBACK=

# Firestore: authenticated roasts append one row to collection `audit_logs` (server-only) for admin analytics.

# Razorpay (legacy fork only). This app bills via Dodo; see Payments block at top of file.

# When true, roast pages unlock the full report for the browser session on "Unlock Full Report" (no payment). Remove or set false when billing is live.
# NEXT_PUBLIC_SKIP_PAYMENT_UNLOCK=true

# Next.js (optional): Calendly / Cal.com / etc. for landing “Book a demo”; falls back to mailto NEXT_PUBLIC_ADMIN_EMAIL or #pricing
# NEXT_PUBLIC_DEMO_BOOKING_URL=

# Credits & promos (client-readable defaults for new signups; set in .env.local)
# Default 20 signup credits (not tied to per-roast cost).
# NEXT_PUBLIC_DEFAULT_NEW_USER_CREDITS=20
# Logged-in POST /api/roast debits when `idToken` is sent. Default = 1 credit per roast.
# ROAST_CREDITS_PER_GENERATION=1
# NEXT_PUBLIC_PROMO_ACTIVE=true
# NEXT_PUBLIC_PROMO_BONUS_ROAST_CREDITS=2
# Set to "true" only if home-page previews should decrement Firestore credits (default: free preview).
# NEXT_PUBLIC_PREVIEW_ROAST_USES_CREDITS=false

# Revenue model: illustrative order value when quick-scan finds no pricing-intent + currency pair (server-side).
# DEFAULT_REVENUE_MODEL_AOV_USD=29

# Credits per purchased unit after Dodo payment success (Pro: credits per cart line item; Agency: credits per bundle)
# PLAN_PRO_AUDIT_CREDITS=1
# PLAN_AGENCY_AUDIT_CREDITS=5

# Optional custom line under the URL input on landing (hero + comparison). Leave unset for no subline.
# NEXT_PUBLIC_ROAST_INPUT_MICROCOPY=
